# Core
APP_ENV=development
APP_TIMEZONE=UTC
LOG_LEVEL=INFO
ORCHESTRATION_MODE=asyncio_multiprocessing_hybrid

# Alpaca (paper trading only)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Storage
DATABASE_URL=sqlite:///./data/trading_ai.db

# Grandmother (global risk + allocation)
GRANDMOTHER_COUNT=1
GRANDMOTHER_MAX_ACCOUNT_DRAWDOWN_PCT=0.05
GRANDMOTHER_MACRO_RISK_REDUCTION_PCT=0.50
GRANDMOTHER_REBALANCE_INTERVAL_MIN=60
GRANDMOTHER_KILL_SWITCH_ENABLED=true
GRANDMOTHER_PRUNE_DAY=SUNDAY
GRANDMOTHER_PRUNE_TIME=23:59
GRANDMOTHER_INTENT_NETTING_ENABLED=true
GRANDMOTHER_INTENT_NETTING_INTERVAL_SEC=5
GRANDMOTHER_HEARTBEAT_INTERVAL_SEC=60
GRANDMOTHER_RESTART_MOTHER_ON_HEARTBEAT_FAIL=true
GRANDMOTHER_CIRCUIT_BREAKER_ACTION=close_all_positions_and_halt
GRANDMOTHER_MACRO_NEWS_ENABLED=true
GRANDMOTHER_MACRO_NEWS_REFRESH_MIN=15
GRANDMOTHER_MACRO_NEWS_SOURCES=https://feeds.reuters.com/reuters/businessNews,https://feeds.a.dj.com/rss/RSSMarketsMain.xml,https://www.marketwatch.com/rss/topstories
GRANDMOTHER_MACRO_RISK_ON_BOOST_PCT=0.15
GRANDMOTHER_WARMUP_BARS=120
GRANDMOTHER_ORDERFLOW_ENABLED=true
GRANDMOTHER_ORDERFLOW_IMBALANCE_VETO_THRESHOLD=-0.30
GRANDMOTHER_ORDERFLOW_DELTA_LOOKBACK_SEC=60
GRANDMOTHER_ORDERFLOW_MIN_DELTA_ALIGNMENT=true
GRANDMOTHER_ORDERFLOW_BUY_PRESSURE_RATIO=3.0
GRANDMOTHER_ORDERFLOW_SPREAD_SPIKE_MULTIPLIER=2.0
GRANDMOTHER_ORDERFLOW_SPREAD_AVG_WINDOW_SEC=300
GRANDMOTHER_ORDERFLOW_SPREAD_HALT_SEC=120
GRANDMOTHER_ORDERFLOW_PRICE_WINDOW_SEC=120
GRANDMOTHER_ORDERFLOW_PRICE_SPIKE_PCT=0.003
GRANDMOTHER_ORDERFLOW_OPEN_INTEREST_REQUIRED_FOR_EXHAUSTION=false
GRANDMOTHER_L2_TAPE_ENABLED=true
GRANDMOTHER_L2_VETO_ENABLED=false
GRANDMOTHER_L2_DEPTH_LEVELS=20
GRANDMOTHER_L2_WHALE_WALL_MIN_NOTIONAL=500000
GRANDMOTHER_L2_WHALE_WALL_RATIO=2.0
GRANDMOTHER_TAPE_LARGE_PRINT_MIN_NOTIONAL=100000
GRANDMOTHER_TAPE_BUY_SWEEP_MIN_COUNT=2
GRANDMOTHER_TAPE_SELL_SWEEP_MIN_COUNT=2
GRANDMOTHER_ORDERFLOW_WS_ENABLED=false
GRANDMOTHER_ORDERFLOW_WS_ASSETS=crypto
GRANDMOTHER_ORDERFLOW_WS_RECONNECT_SEC=5
GRANDMOTHER_ORDERFLOW_WS_MAX_STALENESS_SEC=20
GRANDMOTHER_QUALITY_FILTER_ENABLED=true
GRANDMOTHER_QUALITY_MIN_DAILY_DOLLAR_VOLUME=500000000
GRANDMOTHER_QUALITY_MAX_SPREAD_BPS=12
GRANDMOTHER_QUALITY_REQUIRE_INSTITUTIONAL_OWNERSHIP=false
GRANDMOTHER_QUALITY_MIN_INSTITUTIONAL_OWNERSHIP_PCT=50
GRANDMOTHER_INSTITUTIONAL_OWNERSHIP_PCT_BY_SYMBOL=
GRANDMOTHER_SCANNER_ENABLED=true
GRANDMOTHER_SCANNER_REFRESH_SEC=60
GRANDMOTHER_SCANNER_TOP_N=100
GRANDMOTHER_SCANNER_MIN_ABS_DELTA_NOTIONAL=500000
GRANDMOTHER_SCANNER_FOCUS_TTL_SEC=180
GRANDMOTHER_SCANNER_UNIVERSE_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,META,NVDA,TSLA,AMD,TSM,AVGO,ORCL,CRM,ADBE,INTC,QCOM,NFLX,CSCO,IBM,TXN,AMAT,KLAC,MU,PANW,UBER,SNOW,PLTR,SHOP,JPM,GS,BAC,WFC,MS,C,BLK,SPGI,USB,SCHW,AXP,CB,BX,XLE,CVX,XOM,COP,SLB,EOG,MPC,VLO,OXY,KMI,SPY,QQQ,IWM,DIA,XLK,XLF,XLI,XLV,XLP,XLY,XLC,GLD,TLT,XLU,UNH,LLY,JNJ,PFE,MRK,ABBV,TMO,DHR,ISRG,WMT,COST,HD,LOW,NKE,SBUX,MCD,DIS,KO,PEP,PG,TMUS,T,VZ,CMCSA,CHTR,CAT,DE,GE,BA,HON,UNP,UPS,FDX,LMT,RTX,GME
GRANDMOTHER_SECTOR_DIVERSITY_ENABLED=true
GRANDMOTHER_MAX_POSITIONS_PER_SECTOR=2
GRANDMOTHER_SYMBOL_SECTOR_MAP=AAPL:tech,MSFT:tech,GOOGL:tech,AMZN:tech,META:tech,NVDA:semis,TSM:semis,AMD:semis,AVGO:semis,TSLA:tech,ORCL:tech,CRM:tech,JPM:finance,GS:finance,BAC:finance,WFC:finance,MS:finance,C:finance,BLK:finance,SPGI:finance,XLE:energy,CVX:energy,XOM:energy,COP:energy,SLB:energy,EOG:energy,SPY:index,QQQ:index,IWM:index,DIA:index,GLD:metals,TLT:rates,WMT:consumer_staples,KO:consumer_staples,PG:consumer_staples,GME:consumer_discretionary

# Mother (evolution engine)
MOTHER_COUNT=5
MOTHER_CHILDREN_PER_STRATEGY=10
MOTHER_NIGHTLY_SELECTION_TIME=23:59
MOTHER_WEEKLY_CROSSOVER_DAY=SUNDAY
MOTHER_WEEKLY_CROSSOVER_TIME=23:59
MOTHER_CROSSOVER_ENABLED=true
MOTHER_KILL_COUNT_PER_CYCLE=3
MOTHER_MUTATION_RATE=0.20
MOTHER_MUTATION_STEP=0.10
MOTHER_REPORT_INTERVAL_MIN=60

# Children (execution agents)
CHILD_EXECUTION_MODE=asyncio
CHILD_ORDER_SIZE_MODE=percent_of_mother_allowance
CHILD_MAX_POSITION_PCT=0.10
CHILD_MAX_OPEN_POSITIONS=5
CHILD_DEFAULT_TIMEFRAME=1Min
CHILD_SIGNAL_COOLDOWN_SEC=60
CHILD_INTENT_TIMEOUT_SEC=20
CHILD_MAX_HOLDING_BARS=180
CHILD_ATR_PERIOD=14
CHILD_ATR_STOP_MULTIPLIER=2.0
CHILD_ATR_FLOOR_PCT=0.001
CHILD_LADDER_FIRST_TARGET_PCT=0.015
CHILD_LADDER_SECOND_TARGET_PCT=0.03
CHILD_LADDER_FIRST_FRACTION=0.3333
CHILD_LADDER_SECOND_FRACTION=0.3333
CHILD_L2_ASK_BID_RATIO_THRESHOLD=3.0
CHILD_L2_ASK_BID_HOLD_SEC=10

# Market data / cache
API_MAX_REQUESTS_PER_MIN=200
SNAPSHOT_CACHE_ENABLED=true
SNAPSHOT_CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
ALPACA_STOCK_SNAPSHOT_INTERVAL_SEC=60
ALPACA_CRYPTO_SNAPSHOT_INTERVAL_SEC=5
STOCK_DATA_DELAY_LABEL=T-15

# Paper honesty engine
PAPER_ENABLE_VIRTUAL_FRICTION=true
PAPER_SLIPPAGE_MODEL=percent
PAPER_SLIPPAGE_PCT=0.0005
PAPER_VIRTUAL_COMMISSION_PCT=0.0005
PAPER_LATENCY_SIMULATION_ENABLED=true
PAPER_LATENCY_MIN_MS=50
PAPER_LATENCY_MAX_MS=200

# Persistence / resurrection
LEDGER_BACKEND=sqlite
LEDGER_WRITE_MODE=immediate
LEDGER_BALANCE_SNAPSHOT_INTERVAL_SEC=60
LEDGER_DNA_SNAPSHOT_INTERVAL_MIN=60
RESURRECTION_ENABLED=true
HIVE_STATE_DB_PATH=./data/hive_state.db

# Connectivity safety
FREEZE_TRADING_ON_ALPACA_DISCONNECT=true
UNFREEZE_ONLY_AFTER_RESYNC=true

# Mother universes
MOTHER_SPEEDY_NAME=Speedy
MOTHER_SPEEDY_STYLE=momentum_scalper
MOTHER_SPEEDY_FITNESS_OBJECTIVE=net_profit
MOTHER_SPEEDY_SYMBOLS=BTC/USD,ETH/USD,SOL/USD

MOTHER_TECHIE_NAME=Techie
MOTHER_TECHIE_STYLE=trend_follower
MOTHER_TECHIE_FITNESS_OBJECTIVE=sharpe_ratio
MOTHER_TECHIE_SYMBOLS=NVDA,TSLA,AAPL,MSFT,GOOGL,TSM,AMD

MOTHER_BARGAIN_NAME=Bargain
MOTHER_BARGAIN_STYLE=mean_reversion
MOTHER_BARGAIN_FITNESS_OBJECTIVE=sharpe_ratio
MOTHER_BARGAIN_SYMBOLS=WMT,KO,PG

MOTHER_CHAOS_NAME=Chaos
MOTHER_CHAOS_STYLE=volatility_breakout
MOTHER_CHAOS_FITNESS_OBJECTIVE=net_profit
MOTHER_CHAOS_SYMBOLS=META,AMZN,GME,MSFT,GOOGL,AMD

MOTHER_HEDGE_NAME=Hedge
MOTHER_HEDGE_STYLE=defensive_inverse
MOTHER_HEDGE_FITNESS_OBJECTIVE=sharpe_ratio
MOTHER_HEDGE_SYMBOLS=SPY,GLD,TLT,XLE,JPM,GS

# Runtime / scheduling
SCHEDULER_ENABLED=true
MARKET_EXIT_ON_SHUTDOWN=false
